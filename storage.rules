rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function role() { return request.auth.token.role; }
    function isAdminMaster() { return isSignedIn() && role() == 'admin_master'; }

    // Anexos de demandas: somente autenticados leem; cidadão dono escreve
    match /demandas/{demandaId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // Avatares de usuário
    match /users/{userId}/avatar {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if isAdminMaster();
    }
  }
}
